# Aplicacao
NODE_ENV=production
PORT=3000

# Banco de dados da aplicacao
# Em Docker Compose: use DB_HOST=postgres (service name)
# Fora do Docker (host local): use DB_HOST=127.0.0.1
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=thiltapes_db

# Credenciais admin para manutencao/migrations
DB_ADMIN_HOST=postgres
DB_ADMIN_PORT=5432
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=CHANGE_ME_DB_ADMIN_PASSWORD

